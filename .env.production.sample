# ==========================================
# SetuLink - Production Environment Sample
# ==========================================

# Your Public Domain (Required for Free SSL via Caddy)
# Example: setulink.mycompany.com
DOMAIN=your_domain_here.com

# ------------------------------------------
# Backend Config
# ------------------------------------------
# Replace with your Supabase PostgreSQL connection string!
# Example: postgresql://postgres.xxxx:yourpassword@aws-0-us-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=your_supabase_postgres_url_here

APP_NAME="SetuLink API"
APP_VERSION="1.0.0"

# JWT Secret for Session Tokens
# Generate a secure 32-byte string using: openssl rand -hex 32
SECRET_KEY=replace_this_with_a_secure_random_string

# Email OTP Settings (Optional: Use SendGrid or similar SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# ------------------------------------------
# Gateway Config
# ------------------------------------------
# Set to False so the Gateway actually joins real ZeroTier networks!
MOCK_ZT_API=False

# Your ZeroTier Central API Token
# Get this from https://my.zerotier.com/account
ZT_API_TOKEN=your_zerotier_api_token_here

# The ZeroTier Network ID that all Routers and the Gateway will join
# Create a network at https://my.zerotier.com
GLOBAL_ZT_NETWORK_ID=your_zerotier_network_id_here

# Internal Docker Networking (Do not change)
GATEWAY_URL=http://gateway:8001
